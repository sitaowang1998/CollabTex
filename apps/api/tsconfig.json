{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,

    "rootDir": "src",
    "outDir": "dist",

    "target": "ES2022",
    "lib": ["ES2022"],

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "esModuleInterop": true,
    "types": ["node"],

    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/test/**/*"],
  "references": [{ "path": "../../packages/shared" }]
}
