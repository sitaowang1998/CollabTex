generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProjectRole {
  admin
  editor
  commenter
  reader
}

enum DocumentKind {
  text
  binary
}

enum CommentThreadStatus {
  open
  resolved
}

enum SnapshotRefreshJobStatus {
  queued
  processing
  succeeded
  failed
}

model User {
  id                           String               @id @default(uuid()) @db.Uuid
  // Emails are stored lowercase; auth flows must normalize before reads and writes.
  email                        String               @unique @db.VarChar(320)
  name                         String               @db.VarChar(120)
  passwordHash                 String               @db.Text
  createdAt                    DateTime             @default(now())
  updatedAt                    DateTime             @default(now()) @updatedAt
  memberships                  ProjectMembership[]
  authoredSnaps                Snapshot[]           @relation("SnapshotAuthor")
  requestedSnapshotRefreshJobs SnapshotRefreshJob[] @relation("SnapshotRefreshJobRequester")
  comments                     Comment[]
}

model Project {
  id                  String               @id @default(uuid()) @db.Uuid
  name                String               @db.VarChar(160)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @default(now()) @updatedAt
  tombstoneAt         DateTime?
  memberships         ProjectMembership[]
  documents           Document[]
  snapshots           Snapshot[]
  snapshotRefreshJobs SnapshotRefreshJob[]
  commentThreads      CommentThread[]
}

model ProjectMembership {
  projectId String      @db.Uuid
  userId    String      @db.Uuid
  role      ProjectRole
  createdAt DateTime    @default(now())
  project   Project     @relation(fields: [projectId], references: [id])
  user      User        @relation(fields: [userId], references: [id])

  @@id([projectId, userId])
  @@index([userId])
}

model Document {
  id          String             @id @default(uuid()) @db.Uuid
  projectId   String             @db.Uuid
  path        String             @db.VarChar(1024)
  kind        DocumentKind
  mime        String?            @db.VarChar(255)
  contentHash String?            @db.VarChar(128)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @default(now()) @updatedAt
  project        Project            @relation(fields: [projectId], references: [id])
  textState      DocumentTextState?
  commentThreads CommentThread[]

  @@unique([projectId, path])
}

model DocumentTextState {
  documentId  String   @id @db.Uuid
  yjsState    Bytes
  textContent String   @db.Text
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model Snapshot {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @db.Uuid
  // Each snapshot owns an immutable storage object path.
  storagePath String   @unique @db.VarChar(1024)
  message     String?  @db.Text
  authorId    String?  @db.Uuid
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id])
  author      User?    @relation("SnapshotAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([projectId])
}

model SnapshotRefreshJob {
  id                String                   @id @default(uuid()) @db.Uuid
  projectId         String                   @db.Uuid
  requestedByUserId String?                  @db.Uuid
  status            SnapshotRefreshJobStatus @default(queued)
  attemptCount      Int                      @default(0)
  lastError         String?                  @db.VarChar(512)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @default(now()) @updatedAt
  startedAt         DateTime?
  finishedAt        DateTime?
  project           Project                  @relation(fields: [projectId], references: [id])
  requestedByUser   User?                    @relation("SnapshotRefreshJobRequester", fields: [requestedByUserId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([status, createdAt])
}

model CommentThread {
  id          String              @id @default(uuid()) @db.Uuid
  projectId   String              @db.Uuid
  documentId  String              @db.Uuid
  status      CommentThreadStatus @default(open)
  startAnchor String              @db.VarChar(1024)
  endAnchor   String              @db.VarChar(1024)
  quotedText  String              @db.Text
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @default(now()) @updatedAt
  project     Project             @relation(fields: [projectId], references: [id])
  document    Document            @relation(fields: [documentId], references: [id], onDelete: Cascade)
  comments    Comment[]

  @@index([documentId, createdAt])
  @@index([projectId])
}

model Comment {
  id        String        @id @default(uuid()) @db.Uuid
  threadId  String        @db.Uuid
  authorId  String?       @db.Uuid
  body      String        @db.Text
  createdAt DateTime      @default(now())
  thread    CommentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author    User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([threadId, createdAt])
}
